# Local secret material. Prefer Ansible Vault for committed secrets.
.env
.env.*
*.local.yml
*.local.yaml
iac/ansible/inventories/homelab/group_vars/all/local.yml

# Ansible runtime artifacts.
iac/ansible/.ansible/
*.retry

# Ansible collection dependencies, installed via:
#   ansible-galaxy collection install -r collections/requirements.yml -p collections
# requirements.yml is the source of truth and stays committed.
iac/ansible/collections/ansible_collections/

# OpenTofu/Terraform runtime artifacts and local state.
# .terraform.lock.hcl is intentionally NOT ignored; it should be committed.
iac/opentofu/**/.terraform/
iac/opentofu/**/terraform.tfstate
iac/opentofu/**/terraform.tfstate.backup
iac/opentofu/**/crash.log
iac/opentofu/**/*.tfvars
iac/opentofu/**/*.tfvars.json

.DS_Store

